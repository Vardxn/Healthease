{
  "installCommand": "npm install && cd server && npm install",
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/reminders/trigger",
      "schedule": "0 0 * * *"
    }
  ]
}
