# Environment Variables for HealthEase Server

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017/healthease
# For MongoDB Atlas (cloud):
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/healthease?retryWrites=true&w=majority

# JWT Secret (Generate a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# OpenAI API Key
# Get yours from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Indic Speech-to-Text (choose provider: sarvam or bhashini)
INDIC_STT_PROVIDER=sarvam

# Sarvam Saaras v3 (recommended for Hindi/Urdu/Kashmiri + codemix)
SARVAM_API_KEY=your_sarvam_api_key_here
# Optional overrides
# SARVAM_STT_URL=https://api.sarvam.ai/speech-to-text
# SARVAM_MODEL=saaras:v3
# SARVAM_MODE=codemix
# INDIC_STT_LANGUAGE_HINT=hi-IN

# Bhashini Dhruva pipeline (requires serviceId from ULCA + inference auth)
# BHASHINI_PIPELINE_URL=https://dhruva-api.bhashini.gov.in/services/inference/pipeline/v1
# BHASHINI_AUTHORIZATION=your_bhashini_inference_authorization_token
# BHASHINI_ASR_SERVICE_ID=your_ulca_asr_service_id
# BHASHINI_SOURCE_LANGUAGE=hi
# BHASHINI_AUDIO_FORMAT=wav
# BHASHINI_SAMPLING_RATE=16000

# OpenAI model override (optional)
# OPENAI_CHAT_MODEL=gpt-4o

# Google Cloud Vision API
# Set path to your service account JSON file
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_APPLICATION_CREDENTIALS=./config/google-vision-credentials.json

# Optional: Cloud Storage (for production)
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_BUCKET_NAME=healthease-prescriptions
# AWS_REGION=us-east-1

# Or Cloudinary
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
