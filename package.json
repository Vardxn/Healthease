{
  "name": "healthease",
  "version": "1.0.0",
  "description": "AI-powered healthcare platform for Indians",
  "private": true,
  "scripts": {
    "install:all": "cd server && npm install && cd ../client && npm install",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "dev:python": "cd python-service && ./start_service.sh",
    "dev:all": "bash scripts/start-all.sh",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "start:server": "cd server && npm start",
    "start:client": "cd client && npm start",
    "build:client": "cd client && npm run build"
  },
  "keywords": [
    "healthcare",
    "ai",
    "ocr",
    "medical",
    "prescription",
    "mern"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "lucide-react": "^1.8.0"
  }
}
